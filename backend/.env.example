APP_ENV=development
DATABASE_URL=postgresql+psycopg://fsl_app:admin123@localhost:5432/fsl_learning_hub
DATASETS_ROOT=datasets
ARTIFACTS_ROOT=artifacts
API_HOST=0.0.0.0
API_PORT=8000
SESSION_HOURS=24
PASSWORD_RESET_OTP_MINUTES=10
PASSWORD_RESET_MAX_ATTEMPTS=5
AUTO_BOOTSTRAP_SCHEMA=false
TEACHER_INVITE_SIGNING_SECRET=change-me-teacher-invite-secret
TEACHER_INVITE_DEFAULT_EXPIRY_DAYS=7
TEACHER_INVITE_DEFAULT_MAX_USES=1
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=you@example.com
SMTP_PASSWORD=app-password-here
SMTP_FROM_EMAIL=no-reply@handandheartph.com
SMTP_USE_TLS=true
SMTP_USE_SSL=false
ALPHABET_MODEL_PATH=artifacts/alphabet_model.joblib
ALPHABET_CONFIDENCE_THRESHOLD=0.45
ALPHABET_MIN_TOP2_MARGIN=0.08
NUMBERS_MODEL_PATH=artifacts/numbers_model.joblib
NUMBERS_CONFIDENCE_THRESHOLD=0.5
NUMBERS_MIN_TOP2_MARGIN=0.08
NUMBERS_TEN_MODEL_PATH=artifacts/numbers_ten_motion_model.joblib
NUMBERS_TEN_CONFIDENCE_THRESHOLD=0.5
NUMBERS_TEN_MIN_TOP2_MARGIN=0.0
NUMBERS_TEN_SEQUENCE_FRAMES=16
NUMBERS_TEN_MIN_SEQUENCE_FRAMES=8
NUMBERS_MOTION_MODEL_PATH=artifacts/numbers_motion_model.joblib
NUMBERS_MOTION_CONFIDENCE_THRESHOLD=0.2
NUMBERS_MOTION_MIN_TOP2_MARGIN=0.0
NUMBERS_MOTION_SEQUENCE_FRAMES=14
NUMBERS_MOTION_MIN_SEQUENCE_FRAMES=7
WORDS_MODEL_PATH=artifacts/words_model.joblib
WORDS_CONFIDENCE_THRESHOLD=0.2
WORDS_MIN_TOP2_MARGIN=0.0
WORDS_FORCE_BEST_PREDICTION=true
WORDS_SEQUENCE_FRAMES=20
WORDS_MIN_SEQUENCE_FRAMES=8
WORDS_EXCLUDED_CATEGORIES=FOOD,DRINK
MEDIAPIPE_DETECTION_CONFIDENCE=0.5
MEDIAPIPE_MODEL_COMPLEXITY=1
MEDIAPIPE_FOCUS_ON_HAND_CROP=false
MEDIAPIPE_HAND_CROP_PADDING=0.28
MEDIAPIPE_HAND_CROP_MIN_SIDE_RATIO=0.2
