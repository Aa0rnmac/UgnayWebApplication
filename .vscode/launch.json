{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Backend: FastAPI (Reload)",
      "type": "debugpy",
      "request": "launch",
      "python": "${workspaceFolder}/backend/.venv/Scripts/python.exe",
      "cwd": "${workspaceFolder}/backend",
      "program": "${workspaceFolder}/backend/scripts/run_dev_server.py",
      "envFile": "${workspaceFolder}/backend/.env",
      "args": [
        "--reload"
      ],
      "jinja": true,
      "justMyCode": false,
      "console": "integratedTerminal"
    },
    {
      "name": "Frontend: Next.js Dev",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm.cmd run dev",
      "cwd": "${workspaceFolder}/frontend"
    },
    {
      "name": "Backend: FastAPI",
      "type": "debugpy",
      "request": "launch",
      "python": "${workspaceFolder}/backend/.venv/Scripts/python.exe",
      "cwd": "${workspaceFolder}/backend",
      "program": "${workspaceFolder}/backend/scripts/run_dev_server.py",
      "envFile": "${workspaceFolder}/backend/.env",
      "args": [],
      "jinja": true,
      "justMyCode": false,
      "console": "integratedTerminal"
    }
  ],
  "compounds": [
    {
      "name": "Run Full Stack (Reload)",
      "configurations": [
        "Backend: FastAPI (Reload)",
        "Frontend: Next.js Dev"
      ],
      "stopAll": true
    },
    {
      "name": "Run Full Stack",
      "configurations": [
        "Backend: FastAPI",
        "Frontend: Next.js Dev"
      ],
      "stopAll": true
    }
  ]
}
